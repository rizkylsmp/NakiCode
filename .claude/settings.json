{
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npx tsc *)",
      "Bash(curl -s http://localhost:3001/api/health)",
      "Bash(curl -s http://localhost:3001/api/templates)",
      "Bash(curl -s -H \"Origin: http://localhost:5173\" http://localhost:3001/api/templates)",
      "Bash(curl -s -v -X OPTIONS -H \"Origin: http://localhost:5173\" -H \"Access-Control-Request-Method: GET\" http://localhost:3001/api/templates)",
      "Bash(curl -s -H \"Authorization: Bearer test\" http://localhost:3001/api/admin/stats)",
      "Bash(curl -s http://localhost:3001/api/admin/stats)",
      "Bash(curl -m 5 -s http://localhost:3001/api/admin/stats)",
      "Bash(curl -m 10 -s http://localhost:3001/api/health)",
      "Bash(curl -m 10 -s -H \"Authorization: Bearer admin\" http://localhost:3001/api/admin/stats)",
      "Bash(curl --max-time 5 http://localhost:3001/api/health)",
      "Bash(taskkill /F /IM node.exe)",
      "Bash(powershell -Command \"Stop-Process -Name node -Force\")",
      "Bash(curl --max-time 10 -s http://localhost:3001/api/admin/stats)",
      "Bash(timeout 5)",
      "Bash(npm test *)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "Write-Output '{\"systemMessage\":\"Reminder: update docs/PROJECT_SUMMARY.md -> AI Task Checklist / Changelog with completed or blocked task before ending this session.\"}'",
            "shell": "powershell",
            "timeout": 5,
            "statusMessage": "Reminding summary update"
          }
        ]
      }
    ]
  }
}
